{
    "name": "ai-voice-ordering-copilot",
    "version": "1.0.0",
    "description": "Production-grade AI Voice Ordering Copilot for Restaurants",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "migrate": "ts-node src/database/migrate.ts",
        "seed": "ts-node src/database/seed.ts",
        "lint": "eslint src --ext .ts --fix",
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down"
    },
    "dependencies": {
        "@deepgram/sdk": "^3.9.0",
        "@fastify/cors": "^9.0.1",
        "@fastify/formbody": "^7.4.0",
        "@fastify/helmet": "^11.1.1",
        "@fastify/multipart": "^8.3.0",
        "@fastify/rate-limit": "^9.1.0",
        "@neondatabase/serverless": "^1.0.2",
        "axios": "^1.7.9",
        "dotenv": "^16.4.5",
        "fastify": "^4.28.1",
        "form-data": "^4.0.1",
        "fuse.js": "^7.0.0",
        "openai": "^4.67.3",
        "p-retry": "^6.2.1",
        "pg": "^8.13.1",
        "twilio": "^5.3.7",
        "uuid": "^10.0.0",
        "winston": "^3.17.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^22.10.1",
        "@types/pg": "^8.11.10",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.16.0",
        "@typescript-eslint/parser": "^8.16.0",
        "eslint": "^9.16.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.2"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/src"
        ],
        "testMatch": [
            "**/__tests__/**/*.ts",
            "**/*.test.ts"
        ],
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/**/*.d.ts"
        ]
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
