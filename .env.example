# ─────────────────────────────────────────────────────────────
#  AI Voice Ordering Copilot — Environment Configuration
#  Copy this file to .env and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://your-ngrok-or-domain.com

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=voice_ordering
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_POOL_MIN=2
DB_POOL_MAX=20



# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.2

# ── Deepgram (Speech-to-Text) ─────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
STT_PROVIDER=deepgram        # deepgram | whisper

# ── Twilio (Telephony) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WEBHOOK_SECRET=your_webhook_validation_secret

# ── TTS Service ───────────────────────────────────────────────
TTS_PROVIDER=twilio          # twilio | elevenlabs | google
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── POS Integration ───────────────────────────────────────────
POS_PROVIDER=generic         # generic | petpooja | urbanpiper | posist
POS_API_BASE_URL=https://your-pos-api.com
POS_API_KEY=your_pos_api_key
POS_RESTAURANT_ID=your_restaurant_id
POS_RETRY_ATTEMPTS=3
POS_RETRY_DELAY_MS=2000

# ── Security ──────────────────────────────────────────────────
API_SECRET_KEY=your_internal_api_secret_change_in_production
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Restaurant Config ─────────────────────────────────────────
DEFAULT_RESTAURANT_ID=rest_001
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,hinglish

# ── Cloudflare Workers AI (NL→SQL via SQLCoder-7b-2) ─────────
# Free tier: https://developers.cloudflare.com/workers-ai/
# Leave blank to use GPT-4o as the sole SQL generator
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info               # error | warn | info | debug
LOG_FORMAT=json              # json | pretty
